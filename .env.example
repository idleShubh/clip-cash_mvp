# Local development: use a file-based libsql DB
DB_URL=file:./clipcash.db

# Production (Vercel): use Turso
# DB_URL=libsql://YOUR-DB-NAME.turso.io
# DB_AUTH_TOKEN=eyJhbGciOiJ...

# Cookie-session signing key. Change in production!
SESSION_SECRET=dev-secret-change-me

# Cron endpoint protection. Set the same value in Vercel env vars;
# Vercel Cron will send `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=change-me-in-prod
